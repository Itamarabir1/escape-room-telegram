# Backend env template (copy to backend/.env for local only)
# Never commit real values.

# --- Secrets (Render production: prefer Environment Group `escape-room-secrets`) ---
TELEGRAM_TOKEN=
HF_TOKEN=
GEMINI_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Telegram / Web App routing ---
TELEGRAM_BOT_USERNAME=
TELEGRAM_MINI_APP_SHORT_NAME=
WEBAPP_URL=
VITE_API_URL=

# --- Runtime ---
ENV=
PORT=
GAME_SESSION_TTL=

# --- Infrastructure ---
# Production on Render: DATABASE_URL/REDIS_URL should come from Blueprint bindings
# (fromDatabase / fromService), not hardcoded values.
DATABASE_URL=
REDIS_URL=
REDIS_INTERNAL_URL=
POSTGRES_URL=

# --- Optional non-secret model/config values ---
FRONTEND_ORIGIN_FALLBACK=
GEMINI_MODEL=
GEMINI_IMAGE_MODEL=
HF_FLUX_MODEL=
AWS_REGION=
